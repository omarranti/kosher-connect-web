# ═══════════════════════════════════════
# KOSHER CONNECT WEB — Environment Variables
# Copy this to .env.local and fill in values
# ═══════════════════════════════════════

# Database (PostgreSQL — Neon, Supabase, Railway, etc.)
DATABASE_URL="postgresql://user:password@host:5432/kosher_connect?sslmode=require"

# NextAuth (use https://kosherconnect.app for production)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="" # Generate: openssl rand -base64 32

# Optional: override default admin password when seeding (default: KosherConnect2025!)
# ADMIN_DEFAULT_PASSWORD="your-secure-password"

# Google OAuth (for admin login)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# UploadThing (image uploads)
UPLOADTHING_SECRET=""
UPLOADTHING_APP_ID=""

# Analytics (optional)
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# Vercel (auto-populated on deploy)
VERCEL_URL=""
