# ═══════════════════════════════════════
# KOSHER CONNECT WEB — Environment Variables
# Copy this to .env.local and fill in values
# ═══════════════════════════════════════

# Database (PostgreSQL — Neon, Supabase, Railway, etc.)
# Vercel: set DATABASE_URL in Project → Settings → Environment Variables, then redeploy.
DATABASE_URL="postgresql://user:password@host:5432/kosher_connect?sslmode=require"

# NextAuth v5 (AUTH_SECRET is required in production; also used to sign admin PIN cookie)
AUTH_SECRET="" # Generate: openssl rand -base64 32
AUTH_URL="http://localhost:3000" # Use https://kosherconnect.app for production

# Optional: override default admin password when seeding (default: KosherConnect2025!)
# ADMIN_DEFAULT_PASSWORD="your-secure-password"

# Google OAuth (for admin login)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# UploadThing (image uploads)
UPLOADTHING_SECRET=""
UPLOADTHING_APP_ID=""

# Analytics (optional)
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# Vercel (auto-populated on deploy)
VERCEL_URL=""

# Canonical site URL (fixes metadata / OG URL resolution in production)
NEXT_PUBLIC_SITE_URL="https://kosherconnect.app"
